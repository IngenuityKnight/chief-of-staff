# ─── Chief of Staff · env ─────────────────────────────────────
# Copy this file to `.env.local` and fill in your values.
# None of these are required for the prototype to run — they
# take effect once you wire the real backend to the UI.

# ── n8n webhook (optional) ────────────────────────────────────
# When set, /api/intake forwards captures here instead of
# using the built-in heuristic router.
# Example: https://your-n8n.example.com/webhook/cos-intake
N8N_INTAKE_WEBHOOK=

# ── Notion (optional) ─────────────────────────────────────────
# When set, pages load from Notion instead of lib/mock-data.ts
NOTION_API_KEY=
NOTION_DB_INBOX=
NOTION_DB_TASKS=
NOTION_DB_MEALS=
NOTION_DB_MAINTENANCE=
NOTION_DB_BILLS=
NOTION_DB_CALENDAR=
NOTION_DB_ROSTER=
NOTION_DB_RULES=

# ── LLM (optional, for direct Chief-of-Staff routing) ─────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
