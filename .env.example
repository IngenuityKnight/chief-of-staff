# ── Supabase ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── n8n Workflows ────────────────────────────────────────────────
N8N_INTAKE_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
N8N_CALENDAR_WEBHOOK_SECRET=       # shared secret for /api/sync/calendar inbound

# ── Anthropic (LLM intake routing) ───────────────────────────────
ANTHROPIC_API_KEY=                 # enables Claude routing; falls back to keywords if unset

# ── Google Calendar (outbound write) ─────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=              # one-time OAuth flow; googleapis handles refresh
GOOGLE_CALENDAR_ID=                # e.g. primary or specific calendar ID
GOOGLE_CALENDAR_TIMEZONE=          # e.g. America/Chicago (defaults to America/Chicago)

# ── Plaid (financial data) ───────────────────────────────────────
PLAID_CLIENT_ID=                   # from Plaid dashboard
PLAID_SECRET=                      # sandbox / development / production secret
PLAID_ENV=sandbox                  # sandbox | development | production
N8N_PLAID_SYNC_SECRET=             # shared secret for /api/plaid/sync (set same in n8n env)

# ── App ──────────────────────────────────────────────────────────
APP_EDITOR_PASSWORD=               # enables inline editing on all pages
